					int nextVal = intArray.getVal(targetIndex + 1);
					intArray.setVal(targetIndex, nextVal);
				}
				decPointer(end, 'e');
				size--;
				checkShrink();
				return targetVal;
			}
		}

	}

	public boolean removeByValue(int num) throws EmptyListException {
