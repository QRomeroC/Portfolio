			if (intArray.getVal(targetIndex) == num) {
				return i;
			}
		}
		
		return -1;
	}

	public boolean contains(int num) {
		if (this.isEmpty()) {
			return false;
		}
		for (int i = 0; i <= size; i++) {
			int targetIndex = (start + i) % intArray.length();
			if (intArray.getVal(targetIndex) == num) {
				return true;
			}
		}

		return false;
	}

	public boolean isEmpty() {
		return size == 0;
	}

	public int lastIndexOf(int num) {
		for (int i = size; i >= 0; i--) {
			int targetIndex = (start + i) % intArray.length();
			if (intArray.getVal(targetIndex) == num) {
				return i;
			}
		}
		return -1;

