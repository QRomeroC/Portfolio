		// i can use the same (start + i) % len formula to take care of wrap
		// and reduce confusion of inc and dec.
		if (pointerChar == 's') {
			start = (start + 1) % intArray.length();
		} else if (pointerChar == 'e') {
			end = (end + 1) % intArray.length();
		}
	}

	private void decPointer(char pointerChar) {
//		if (pointerChar == 's') {
//			if (start == intArray.length() - 1) {
//				start = 0;
