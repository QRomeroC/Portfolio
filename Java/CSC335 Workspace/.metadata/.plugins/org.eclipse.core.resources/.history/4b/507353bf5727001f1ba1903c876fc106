	public int size() {
		//or retrun n?
		return this.size;
	}
	
	private boolean isFull() {
		return n == (size - 1);
	}
	
	private void growArray() {
		int newArray[] = new int[this.size * 2];
		for (int i = 0; i < size; i++){
			newArray[i] = intArray[i];
		}
		intArray = newArray;
