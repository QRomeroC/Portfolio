	public int set(int index, int num) throws Exception {
		if (this.isEmpty()) {
			throw new Exception();
		}

		if (index > n) {
			throw new Exception();
		}

		int retEle = intArray[index];
		intArray[index] = num;

		return retEle;
	}

	public int size() {
		// or retrun n?
		return this.size;
	}

	private boolean isFull() {
		return n == (size - 1);
	}

	private void growArray() {
		int newArray[] = new int[this.size * 2];
		for (int i = 0; i < size; i++) {
			newArray[i] = intArray[i];
		}
		intArray = newArray;
	}

	private void shrinkArray() {
		int[] newArray = new int[this.size / 2];
		size = size / 2;
		for (int i = 0; i < size; i++) {
			newArray[i] = this.intArray[i];
		}
		intArray = newArray;
	}
