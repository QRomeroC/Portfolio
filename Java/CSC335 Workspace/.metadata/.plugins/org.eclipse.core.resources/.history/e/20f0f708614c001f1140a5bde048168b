
public class ArraySort {
	
	public static void sort(Array array, int num, int d) {
	
		switch (num) {
			case 1:
				quickSort(array, 0, array.length() - 1);
				return;
			case 2:
				maxHeapSort(array);
				return;
			case 3:
				insertionSort(array);
				return;
			case 4:
				relativeAddressing(array, d);
				return;
			case 5:
				mergeSort(array);
				return;
			case 6:
				mergeSort(array);
			case 7:
				maxHeapSort(array);
				return;
		}
	}//end of public method sort
	
	private static void quickSort(Array array, int i, int j) {
		//base case (1): i (left most pointer) is equal to or grater than
		//j (right most pointer - end of array)
		if (i >= j) {
			return;
		}
		//base case (2): i is negative, i/j is grater than or equal to length of the array 
		if (i < 0 || i >= array.length() || j >= array.length()) {
			return;
		}
		//get val
		int currVal = array.getVal(i);
		//make referance to the index i and i + 1
		int currIndex = i;
		int nextIndex = i + 1;
		
		for (int k = nextIndex; k <= j; k++) {
			if (array.getVal(k) < currVal) {
				array.swap(nextIndex, k);
				array.swap(currIndex, nextIndex);
				currIndex++;
				nextIndex++;
			} else if (array.getVal(k) == currVal) {
				array.swap(nextIndex, k);
				nextIndex++;
			}
		}
		//recursive call(s)
		//one on i (left most ref) to (currInex (a ref to i) - 1)
		//one on nextIndex (a ref to i + 1) and j (right most ref)
		quickSort(array, i, currIndex - 1);
		quickSort(array, nextIndex, j);
	}
	
	private static void maxHeapSort(Array array) {
		//bottom up heap construction
		//parent - floor(k/2)
		//left child - (2k) + 1
		//right child - (2k) + 2
		
		for (int i = array.length()/2; i >= 0; i--) {
			sink(array, i, array.length() - 1);
		}
		
		int m = array.length() - 1;
		
		while (m > 0) {
			array.swap(0, m);
			m--;
			sink(array, 0, m);
		}
		
	}
	
