	private Deque<Loc> getNeighbors(Loc location) {
		//get neighbors checks if UP, RIGHT, BOTTOM, LEFT of current location
		//is in bounds using grid.getLoc(), if in bounds then we add to neighbor list
		int row = location.getRow();
		int col = location.getCol();
		Deque<Loc> neighbors = new Deque<>();
		
		if (grid.getLoc(row - 1, col) != null) {
			neighbors.addToBack(grid.getLoc(row - 1, col));
		}
		if (grid.getLoc(row, col + 1) != null) {
			neighbors.addToBack(grid.getLoc(row, col + 1));
		}
		if (grid.getLoc(row + 1, col) != null) {
			neighbors.addToBack(grid.getLoc(row + 1, col));
		}
		if (grid.getLoc(row, col - 1) != null) {
			neighbors.addToBack(grid.getLoc(row, col - 1));
		}
		
		return neighbors;
		
	}
	
	private void queNeighbors(Deque<Loc> toQue) throws EmptyDequeException{
		while (!toQue.isEmpty()) {
			deque.addToBack(toQue.getFirst());
		}
		return;
	}
	
	private Deque<Loc> mergeQues(Deque<Loc> que1, Deque<Loc> que2) {
		while (!que2.isEmpty()) {
			try {
				que1.addToBack(que2.getFirst());
			} catch (EmptyDequeException e) {
				// TODO Auto-generated catch block
				e.printStackTrace();
			}
		}
		return que1;
	}
	private void convertPath() {
