import java.util.ArrayList;

/**
 * Author: Cesar D. Quihuis-Romero 
 * Purpose: this class, in concert with other
 * associated classes, will utilize a deque data structure to "solve" a word
 * search puzzle. It will find a series of "paths" (tuples) corresponding to the
 * (row, col) location of the individual characters making up the word
 * 
 * Methods: 
 * public Puzzle(Grid grid): constructor taking as argument a Grid
 * object 
 * public String find(String word, int r, int c): find and return
 * (String) path containing the tuple pairs starting at (r, c) and going up,
 * right,down,left to form the word required.
 */

public class Puzzle {
	private Grid grid;
	private Deque<Loc> deque;
	private String searchWord = "";
	private String path = "";
	private Deque<Loc> finalPath = new Deque<>();

	@SuppressWarnings("rawtypes")
	public Puzzle(Grid grid) {
		this.grid = grid;
		deque = new Deque<>();
	}

	public String find(String word, int r, int c) {
		//find will start with a BFS to find the first letter and if found DFS to see if a 
		//mathcing word is yeilded
		searchWord = word;
		Loc startPos = grid.getLoc(r, c);
		System.out.println("(line 50) startPos = " + startPos.toString());
		if (startPos != null) {
			deque.addToFront(startPos);
			BFS();
		}
		System.out.println("line 54");
		System.out.println("\n");
		deque.printDeque();
		System.out.println("\n");
		
		System.out.println("(line 60) path len = " + path.length());
		if (!path.isEmpty()) {
			return path;
		}
		
		return "Not Found";
	}

	@SuppressWarnings({ "unchecked", "rawtypes", "unlikely-arg-type" })
	private void BFS() {

		if (deque.isEmpty()) {
			return;
		}
		
		try {

			while (!deque.isEmpty()) {
				Loc firstObject = deque.getFirst();
				if (firstObject.getStatus()) {
					queNeighbors(getNeighbors(firstObject));
				} else {
					
					firstObject.setStatus(true);
					
					if (firstObject.getVal().equals(String.valueOf(searchWord.charAt(0)))) {
						Deque<Loc> neighbors = new Deque<>();
						neighbors.addToFront(firstObject);
						int index = 1;
						DFS(neighbors, index);
					}
					
					queNeighbors(getNeighbors(firstObject));
				}
				
			}
		} catch (EmptyDequeException e) {
			// TODO Auto-generated catch block
			e.printStackTrace();
		}
	
	}

	@SuppressWarnings("unlikely-arg-type")
	private void DFS(Deque<Loc> neighborsToCheck, int index) {
		
		if (index == searchWord.length()) {
			convertPath();
			return;
		}
		
		if (neighborsToCheck.isEmpty()) {
			System.out.println("DFS Empty");
			return;
		}
		
		try {
			Deque<Loc> newNeighbors = getNeighbors(neighborsToCheck.peekFirst());
			neighborsToCheck = mergeQues(neighborsToCheck, newNeighbors);
			
			while (!neighborsToCheck.isEmpty()) {
				Loc firstObj = neighborsToCheck.getFirst();
				if (firstObj.getVal().equals(String.valueOf(searchWord.charAt(index)))) {
					finalPath.addToBack(firstObj);
					Deque<Loc> nextNeighbors = getNeighbors(firstObj);
					DFS(nextNeighbors, index++);
				}
			}
			
		} catch (EmptyDequeException e) {
			// TODO Auto-generated catch block
			e.printStackTrace();
		}
				
	}

	private Deque<Loc> getNeighbors(Loc location) {
		//get neighbors checks if UP, RIGHT, BOTTOM, LEFT of current location
		//is in bounds using grid.getLoc(), if in bounds then we add to neighbor list
		int row = location.getRow();
		int col = location.getCol();
		Deque<Loc> neighbors = new Deque<>();
		
		if (grid.getLoc(row - 1, col) != null) {
			neighbors.addToBack(grid.getLoc(row - 1, col));
		}
		if (grid.getLoc(row, col + 1) != null) {
			neighbors.addToBack(grid.getLoc(row, col + 1));
		}
		if (grid.getLoc(row + 1, col) != null) {
			neighbors.addToBack(grid.getLoc(row + 1, col));
		}
		if (grid.getLoc(row, col - 1) != null) {
			neighbors.addToBack(grid.getLoc(row, col - 1));
		}
		
		return neighbors;
		
	}
	
	private void queNeighbors(Deque<Loc> toQue) throws EmptyDequeException{
		while (!toQue.isEmpty()) {
			deque.addToBack(toQue.getFirst());
		}
		return;
	}
	
	private Deque<Loc> mergeQues(Deque<Loc> que1, Deque<Loc> que2) {
		while (!que2.isEmpty()) {
			try {
				que1.addToBack(que2.getFirst());
			} catch (EmptyDequeException e) {
				// TODO Auto-generated catch block
				e.printStackTrace();
			}
		}
		return que1;
	}
	private void convertPath() {
		while (!finalPath.isEmpty()) {
			try {
				path += finalPath.getFirst().getVal().toString();
			} catch (EmptyDequeException e) {
				// TODO Auto-generated catch block
				e.printStackTrace();
			}
		}
		return;
	}
